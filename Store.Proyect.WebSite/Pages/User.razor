@page "/user"
@using Store.Proyect.WebSite.Dtos
@using Store.Proyect.WebSite.Services
@using Store.Proyect.WebSite.Services.Interfaces
@inject IUserService UserService

<h3>Users</h3>

@if (users == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Email</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>
                        <button class="btn btn-primary" @onclick="() => EditUser(user)">Edit</button>
                        <button class="btn btn-danger" @onclick="() => DeleteUser(user.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<hr />

<h3>@(isEditing ? "Edit User" : "Add New User")</h3>

<EditForm Model="@userModel" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-group">
        <label for="name">Name:</label>
        <InputText id="name" class="form-control" @bind-Value="userModel.Name" />
    </div>
    
    <div class="form-group">
        <label for="email">Email:</label>
        <InputText id="email" class="form-control" @bind-Value="userModel.Email" />
    </div>
    
    <div class="form-group">
        <label for="password">Password:</label>
        <InputText type="password" id="password" class="form-control" @bind-Value="userModel.Password" />
    </div>

    <button type="submit" class="btn btn-success">@(isEditing ? "Update" : "Add")</button>
    @if (isEditing)
    {
        <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
    }
</EditForm>

@code {
    private List<UserDto>? users;
    private UserDto userModel = new();
    private bool isEditing = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        users = await UserService.GetAllAsync();
    }

    private async Task HandleSubmit()
    {
        if (isEditing)
        {
            await UserService.UpdateAsync(userModel);
        }
        else
        {
            await UserService.AddAsync(userModel);
        }

        userModel = new();
        isEditing = false;
        await LoadData();
        StateHasChanged();
    }

    private void EditUser(UserDto user)
    {
        userModel = new UserDto 
        { 
            Id = user.Id, 
            Name = user.Name,
            Email = user.Email
        };
        isEditing = true;
    }

    private void CancelEdit()
    {
        userModel = new();
        isEditing = false;
    }

    private async Task DeleteUser(int id)
    {
        await UserService.DeleteAsync(id);
        await LoadData();
        StateHasChanged();
    }
}